VITE_API_URL=http://localhost:8000
# Google OAuth client ID — paste the same Web client ID you set in
# backend/.env's GOOGLE_OAUTH_CLIENT_ID. Get one at
# https://console.cloud.google.com/apis/credentials.
# Leave empty to hide the "Sign in with Google" button and use only
# email/password.
VITE_GOOGLE_OAUTH_CLIENT_ID=
